---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
---

<BaseLayout sideBarActiveItemID="home">
  <div class="pb-12 mt-5">
    <div class="text-xl py-1">Hello!</div>
    <div class="text-5xl font-bold">I'm Leo Matyushkin</div>
    <div class="text-3xl py-3 font-bold">Python & JavaScript Developer</div>
    <div class="py-2">
      <text class="text-lg">
        I'm from Saint Petersburg, Russia. I program in Python and JavaScript,
        write texts about <a href="/posts" class="underline">programming</a> and
        <a href="/links" class="underline">other stuff</a>.
      </text>
    </div>
  </div>

  <div>
    <div class="text-3xl w-full font-bold mb-5">Projects</div>
  </div>

  <HorizontalCard
    title="Apifornia"
    img="/post_img.webp"
    desc="Web data scraping and web crawling platform with API marketplace, storage for collected data, and webhooks."
    url="https://apifornia.com"
    target="_blank"
    badge="MAIN"
  />

  <div class="mt-10">
    <div class="text-2xl w-full font-bold mb-5">Contact</div>
    <div class="py-2">
      <text class="text-lg">
        Email: <a href="mailto:leva.matyushkin@gmail.com" class="underline">leva.matyushkin@gmail.com</a>
      </text>
    </div>
    <div class="py-2">
      <text class="text-lg">
        If you like what I do, you can <a href="/donate" class="underline">support</a> me.
      </text>
    </div>
  </div>
</BaseLayout>
